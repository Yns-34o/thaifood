# ------------------------------------------------------------------
#  Configuration du dashboard admin (OPTIONNEL)
#  Ces valeurs ont des valeurs par défaut, ce fichier n'est pas requis.
#  Pour changer les identifiants, copiez ce fichier en ".env.local"
#  et modifiez les valeurs ci-dessous. Relancez ensuite le serveur.
# ------------------------------------------------------------------

# Identifiant de connexion admin
ADMIN_USERNAME=adminthaifood

# Mot de passe de connexion admin
ADMIN_PASSWORD=meilleurthai77

# Secret utilisé pour signer la session (changez-le en production)
SESSION_SECRET=thai-food-77-local-session-secret-change-me

# ------------------------------------------------------------------
#  FIREBASE (à configurer plus tard — voir README, section "Passer à Firebase")
#  Décommentez et remplissez quand vous serez prêt :
# ------------------------------------------------------------------
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
